# ==============================================================================
# OPTIMUS CORE - CONFIGURAÇÕES DE AMBIENTE
# ==============================================================================

# Defina o ambiente: development, staging ou production
APP_ENV=development
PORT=8000

# 🤖 INTELIGÊNCIA ARTIFICIAL (PROVEDORES DE IA / LLM)
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_API_KEY=your_gemini_api_key_here

# 🧠 EVENT BUS, FILAS & CACHE (REDIS)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# 🔥 BANCO DE DADOS (GOOGLE CLOUD FIRESTORE)
FIREBASE_PROJECT_ID=optimus-robot-dev

# --- Modo Produção / Staging ---
# Caminho absoluto ou relativo para o arquivo JSON da sua Service Account do Google Cloud.
# Deixe em branco se for utilizar o Emulador Local em desenvolvimento.
GOOGLE_APPLICATION_CREDENTIALS=

# --- Modo Desenvolvimento / Testes Locais (Emulador) ---
# Para rodar offline sem gastar cota, descomente a linha abaixo após iniciar o emulador:
# FIRESTORE_EMULATOR_HOST=localhost:8080